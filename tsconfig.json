{
    "compilerOptions": {
        "target": "es2020",
        "module": "esnext",
        "moduleResolution": "node",
        "lib": [
            "dom",
            "dom.iterable",
            "esnext"
        ],
        "allowJs": true,
        "sourceMap": true,
        "strict": true,
        "forceConsistentCasingInFileNames": true,
        "noEmitOnError": true,
        "skipLibCheck": true,
        "esModuleInterop": true
    },
    "include": [
        "_includes/assets/js/**/*.ts"
    ]
}
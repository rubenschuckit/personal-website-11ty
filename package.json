{
  "scripts": {
    "dev": "tsc && npm-run-all --parallel dev:*",
    "dev:tsc": "tsc -w --preserveWatchOutput",
    "dev:eleventy": "tinacms dev -c \"eleventy --serve\"",
    "build": "tsc && tinacms build && eleventy",
    "watch": "tsc && tinacms dev -c \"eleventy --watch\"",
    "debug": "DEBUG=* eleventy"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.1.2",
    "@11ty/eleventy-plugin-syntaxhighlight": "^5.0.2",
    "@tinacms/cli": "^2.1.9",
    "@types/node": "^25.3.5",
    "luxon": "^3.7.2",
    "markdown-it": "^14.1.0",
    "markdown-it-anchor": "^9.2.0",
    "markdown-it-attrs": "^4.3.1",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@11ty/eleventy-img": "^6.0.4",
    "@11ty/eleventy-navigation": "^1.0.5",
    "clean-css": "^5.3.3",
    "html-minifier": "^4.0.0",
    "terser": "^5.34.0",
    "tinacms": "^3.6.1"
  }
}